# Database Connection
# PostgreSQL Connection URL (Local or Remote)
DATABASE_URL=postgresql://postgres:1234@localhost:5432/rottra

# Better Auth Configuration
BETTER_AUTH_SECRET=your_32_character_secret_key_here
BETTER_AUTH_URL=http://localhost:5173

# Server Settings
PORT=5173
NODE_ENV=development

# Heartbeat & Autonomous Engine settings
HEARTBEAT_INTERVAL_MS=60000

# AI Studio (Phim trường AI) configuration
# Muapi.ai key for generating image/video ads
NEXT_PUBLIC_MUAPI_KEY=your_muapi_key_here

# Frontend API Endpoint configuration (used in static build environments like Cloudflare/AWS)
VITE_API_URL=http://localhost:8080
